# Eureka Backend — Environment Variables
# Copy this to .env and fill in your values.

# ── LLM / Ollama ──────────────────────────────────────────────────────────────
EUREKA_OLLAMA_BASE_URL=http://localhost:11434
EUREKA_CHAT_MODEL=qwen2.5vl:7b
EUREKA_EMBED_MODEL=bge-m3

# ── HuggingFace Reranker ──────────────────────────────────────────────────────
EUREKA_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Qdrant ────────────────────────────────────────────────────────────────────
EUREKA_QDRANT_URL=http://localhost:6333
EUREKA_QDRANT_COLLECTION=legal_kb

# ── Supabase ──────────────────────────────────────────────────────────────────
EUREKA_SUPABASE_URL=https://your-project.supabase.co
EUREKA_SUPABASE_KEY=your-supabase-anon-or-service-key

# ── RAG Params ────────────────────────────────────────────────────────────────
EUREKA_RETRIEVAL_TOP_K=20
EUREKA_RERANK_TOP_N=5

# ── Chunking ──────────────────────────────────────────────────────────────────
EUREKA_CHUNK_SIZE=512
EUREKA_CHUNK_OVERLAP=64
